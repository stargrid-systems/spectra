{
  "openapi": "3.1.0",
  "info": {
    "title": "Aperture API",
    "description": "",
    "contact": {
      "name": "Simon Berger",
      "email": "simon@siku2.io"
    },
    "license": {
      "name": "AGPL-3.0-or-later",
      "identifier": "AGPL-3.0-or-later"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/artifacts": {
      "get": {
        "summary": "Lists stored artifact keys, each with its newest version.",
        "operationId": "listArtifacts",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Match keys containing this substring.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_ArtifactSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/artifacts/{key}": {
      "get": {
        "summary": "Returns one artifact key with its newest version.",
        "operationId": "getArtifact",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifact",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactSummaryResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown artifact"
          }
        }
      }
    },
    "/api/v1/artifacts/{key}/versions": {
      "get": {
        "summary": "Lists the stored versions of an artifact.",
        "operationId": "listArtifactVersions",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort by. Defaults to downloaded time.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/VersionSortParam"
            }
          },
          {
            "name": "media_type",
            "in": "query",
            "description": "Only versions with this exact media type.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "Only versions with this exact version string.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Versions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_ArtifactVersionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/artifacts/{key}/versions/{digest}": {
      "get": {
        "summary": "Returns one stored version.",
        "operationId": "getArtifactVersion",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "digest",
            "in": "path",
            "description": "Content digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactVersionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown version"
          }
        }
      },
      "delete": {
        "summary": "Evicts one stored version and its blob, if no other version needs it.",
        "operationId": "deleteArtifactVersion",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "digest",
            "in": "path",
            "description": "Content digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Version evicted"
          },
          "404": {
            "description": "Unknown version"
          }
        }
      }
    },
    "/api/v1/downloads": {
      "get": {
        "summary": "Lists download attempts, optionally filtered by status and artifact key.\nRunning attempts carry live byte progress.",
        "operationId": "listDownloads",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Only attempts in this state.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/DownloadStatusParam"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Only attempts for this artifact key.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Downloads",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_DownloadResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/logs": {
      "get": {
        "summary": "Lists log events with optional filtering.",
        "operationId": "listLogs",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction. Defaults to descending (newest first).",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "min_level",
            "in": "query",
            "description": "Only events at this severity or higher.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/LevelResponse"
            }
          },
          {
            "name": "target",
            "in": "query",
            "description": "Only events whose target starts with any of these (comma-separated)\nprefixes. Example: `aperture,aperture_http`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Substring search across message, target, and structured fields.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "span_id",
            "in": "query",
            "description": "Only events belonging to this span.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Only events at or after this time (RFC 3339).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "until",
            "in": "query",
            "description": "Only events at or before this time (RFC 3339).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Structured field filter as a JSON object, e.g. `{\"key\":\"value\"}`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Log events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_LogEventResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/logs/boots": {
      "get": {
        "summary": "Lists distinct boot sessions, newest first.",
        "operationId": "listLogBoots",
        "responses": {
          "200": {
            "description": "Boot sessions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BootResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/logs/spans": {
      "get": {
        "summary": "Lists tracing spans with optional filtering.",
        "operationId": "listSpans",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction. Defaults to descending (newest first).",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "min_level",
            "in": "query",
            "description": "Only spans at this severity or higher.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/LevelResponse"
            }
          },
          {
            "name": "target",
            "in": "query",
            "description": "Only spans whose target starts with any of these (comma-separated)\nprefixes. Example: `aperture,aperture_storage`.",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Only spans started at or after this time (RFC 3339).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "until",
            "in": "query",
            "description": "Only spans started at or before this time (RFC 3339).",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "parent_id",
            "in": "query",
            "description": "Only direct children of this span id.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "parent_null",
            "in": "query",
            "description": "When true, only root spans (no parent) are returned.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fields",
            "in": "query",
            "description": "Structured field filter as a JSON object, e.g. `{\"key\":\"value\"}`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Spans",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_LogSpanResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/logs/spans/{id}": {
      "get": {
        "summary": "Returns a single span with its events.",
        "operationId": "getSpan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Span id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Span with events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogSpanDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown span"
          }
        }
      }
    },
    "/api/v1/logs/targets": {
      "get": {
        "summary": "Lists distinct log targets for autocomplete.",
        "operationId": "listLogTargets",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Only targets starting with this prefix.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Target names",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/version": {
      "get": {
        "summary": "Returns version information about the gateway.",
        "operationId": "getGatewayVersion",
        "responses": {
          "200": {
            "description": "Gateway version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArtifactSummaryResponse": {
        "type": "object",
        "description": "A distinct artifact key with its newest version, for `GET\n/api/v1/artifacts`.",
        "required": [
          "key",
          "version_count",
          "source",
          "digest",
          "size_bytes",
          "downloaded_at"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "description": "Content digest of the newest version."
          },
          "downloaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the newest version was downloaded."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Stored blob size of the newest version, in bytes."
          },
          "source": {
            "type": "string",
            "description": "Where the newest version came from."
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable version of the newest version, if known."
          },
          "version_count": {
            "type": "integer",
            "format": "int64",
            "description": "How many versions of this key are stored."
          }
        }
      },
      "ArtifactVersionResponse": {
        "type": "object",
        "description": "One stored version of an artifact.",
        "required": [
          "key",
          "digest",
          "source",
          "size_bytes",
          "downloaded_at"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "description": "Content digest of the stored blob."
          },
          "downloaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this version was downloaded."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "media_type": {
            "type": [
              "string",
              "null"
            ],
            "description": "OCI media type, if applicable."
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Stored blob size in bytes."
          },
          "source": {
            "type": "string",
            "description": "Where this version came from."
          },
          "verified_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When this version was last verified, if ever."
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable version, if known."
          }
        }
      },
      "BootResponse": {
        "type": "object",
        "description": "One boot session observed in the log store, returned by\n`GET /api/v1/logs/boots`.",
        "required": [
          "boot_id",
          "first_seen",
          "last_seen",
          "event_count",
          "is_current"
        ],
        "properties": {
          "boot_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique boot id (UUID)."
          },
          "event_count": {
            "type": "integer",
            "format": "int64",
            "description": "Number of events recorded so far in this boot."
          },
          "first_seen": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the earliest event in this boot."
          },
          "is_current": {
            "type": "boolean",
            "description": "True if this is the currently running gateway boot."
          },
          "last_seen": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the latest event in this boot."
          }
        }
      },
      "DownloadProgressResponse": {
        "type": "object",
        "description": "Live byte progress of a running download.",
        "required": [
          "done_bytes"
        ],
        "properties": {
          "done_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Bytes transferred so far.",
            "minimum": 0
          },
          "total_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Expected total bytes, if known.",
            "minimum": 0
          }
        }
      },
      "DownloadResponse": {
        "type": "object",
        "description": "One download attempt, returned by `GET /api/v1/downloads`.",
        "required": [
          "id",
          "key",
          "source",
          "status",
          "started_at"
        ],
        "properties": {
          "digest": {
            "type": [
              "string",
              "null"
            ],
            "description": "Resolved content digest, if it got that far."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Failure detail, if any."
          },
          "finished_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When it finished, if it did."
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Attempt id."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "progress": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/DownloadProgressResponse",
                "description": "Live byte progress, present only while running."
              }
            ]
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Bytes transferred, recorded on completion."
          },
          "source": {
            "type": "string",
            "description": "Where it was fetched from."
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the attempt started."
          },
          "status": {
            "$ref": "#/components/schemas/DownloadStatusResponse",
            "description": "Lifecycle state."
          }
        }
      },
      "DownloadStatusParam": {
        "type": "string",
        "description": "Filter for download status.",
        "enum": [
          "running",
          "succeeded",
          "failed",
          "interrupted"
        ]
      },
      "DownloadStatusResponse": {
        "type": "string",
        "description": "Lifecycle state of a download attempt.",
        "enum": [
          "running",
          "succeeded",
          "failed",
          "interrupted"
        ]
      },
      "LevelResponse": {
        "type": "string",
        "description": "Severity level of a log event or span.",
        "enum": [
          "trace",
          "debug",
          "info",
          "warn",
          "error"
        ]
      },
      "LogEventResponse": {
        "type": "object",
        "description": "A single log event, returned by `GET /api/v1/logs`.",
        "required": [
          "id",
          "level",
          "target",
          "timestamp"
        ],
        "properties": {
          "fields": {
            "description": "All structured fields as a JSON object, if any."
          },
          "file": {
            "type": [
              "string",
              "null"
            ],
            "description": "Source file, if available."
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Event id."
          },
          "level": {
            "$ref": "#/components/schemas/LevelResponse",
            "description": "Severity level."
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Source line, if available."
          },
          "message": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable message, if any."
          },
          "span_id": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Span this event belongs to, if any."
          },
          "target": {
            "type": "string",
            "description": "Module path that emitted the event."
          },
