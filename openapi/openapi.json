{
  "openapi": "3.1.0",
  "info": {
    "title": "Aperture API",
    "description": "",
    "contact": {
      "name": "Simon Berger",
      "email": "simon@siku2.io"
    },
    "license": {
      "name": "AGPL-3.0-or-later",
      "identifier": "AGPL-3.0-or-later"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/artifacts": {
      "get": {
        "summary": "Lists stored artifact keys, each with its newest version.",
        "operationId": "list_artifacts",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Match keys containing this substring.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_ArtifactSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/artifacts/{key}": {
      "get": {
        "summary": "Returns one artifact key with its newest version.",
        "operationId": "get_artifact",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Artifact",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactSummaryResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown artifact"
          }
        }
      }
    },
    "/api/v1/artifacts/{key}/versions": {
      "get": {
        "summary": "Lists the stored versions of an artifact.",
        "operationId": "list_versions",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort by. Defaults to downloaded time.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/VersionSortParam"
            }
          },
          {
            "name": "media_type",
            "in": "query",
            "description": "Only versions with this exact media type.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "Only versions with this exact version string.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Versions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_ArtifactVersionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/artifacts/{key}/versions/{digest}": {
      "get": {
        "summary": "Returns one stored version.",
        "operationId": "get_version",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "digest",
            "in": "path",
            "description": "Content digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtifactVersionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown version"
          }
        }
      },
      "delete": {
        "summary": "Evicts one stored version and its blob, if no other version needs it.",
        "operationId": "delete_version",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Artifact key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "digest",
            "in": "path",
            "description": "Content digest",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Version evicted"
          },
          "404": {
            "description": "Unknown version"
          }
        }
      }
    },
    "/api/v1/downloads": {
      "get": {
        "summary": "Lists download attempts, optionally filtered by status and artifact key.\nRunning attempts carry live byte progress.",
        "operationId": "list_downloads",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum rows to return. Defaults to 50.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50,
              "maximum": 200,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor from a page's `next_cursor` or `prev_cursor`.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/OrderParam"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Only attempts in this state.",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/DownloadStatusParam"
            }
          },
          {
            "name": "key",
            "in": "query",
            "description": "Only attempts for this artifact key.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Downloads",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page_DownloadResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/version": {
      "get": {
        "summary": "Returns version information about the gateway.",
        "operationId": "get_gateway_version",
        "responses": {
          "200": {
            "description": "Gateway version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ArtifactSummaryResponse": {
        "type": "object",
        "description": "A distinct artifact key with its newest version, for `GET /api/v1/artifacts`.",
        "required": [
          "key",
          "version_count",
          "source",
          "digest",
          "size_bytes",
          "downloaded_at"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "description": "Content digest of the newest version."
          },
          "downloaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the newest version was downloaded."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Stored blob size of the newest version, in bytes."
          },
          "source": {
            "type": "string",
            "description": "Where the newest version came from."
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable version of the newest version, if known."
          },
          "version_count": {
            "type": "integer",
            "format": "int64",
            "description": "How many versions of this key are stored."
          }
        }
      },
      "ArtifactVersionResponse": {
        "type": "object",
        "description": "One stored version of an artifact.",
        "required": [
          "key",
          "digest",
          "source",
          "size_bytes",
          "downloaded_at"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "description": "Content digest of the stored blob."
          },
          "downloaded_at": {
            "type": "string",
            "format": "date-time",
            "description": "When this version was downloaded."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "media_type": {
            "type": [
              "string",
              "null"
            ],
            "description": "OCI media type, if applicable."
          },
          "size_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Stored blob size in bytes."
          },
          "source": {
            "type": "string",
            "description": "Where this version came from."
          },
          "verified_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When this version was last verified, if ever."
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable version, if known."
          }
        }
      },
      "DownloadProgressResponse": {
        "type": "object",
        "description": "Live byte progress of a running download.",
        "required": [
          "done_bytes"
        ],
        "properties": {
          "done_bytes": {
            "type": "integer",
            "format": "int64",
            "description": "Bytes transferred so far.",
            "minimum": 0
          },
          "total_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Expected total bytes, if known.",
            "minimum": 0
          }
        }
      },
      "DownloadResponse": {
        "type": "object",
        "description": "One download attempt, returned by `GET /api/v1/downloads`.",
        "required": [
          "id",
          "key",
          "source",
          "status",
          "started_at"
        ],
        "properties": {
          "digest": {
            "type": [
              "string",
              "null"
            ],
            "description": "Resolved content digest, if it got that far."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Failure detail, if any."
          },
          "finished_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When it finished, if it did."
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Attempt id."
          },
          "key": {
            "type": "string",
            "description": "Logical artifact key."
          },
          "progress": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/DownloadProgressResponse",
                "description": "Live byte progress, present only while running."
              }
            ]
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Bytes transferred, recorded on completion."
          },
          "source": {
            "type": "string",
            "description": "Where it was fetched from."
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the attempt started."
          },
          "status": {
            "$ref": "#/components/schemas/DownloadStatusResponse",
            "description": "Lifecycle state."
          }
        }
      },
      "DownloadStatusResponse": {
        "type": "string",
        "description": "Lifecycle state of a download attempt.",
        "enum": [
          "running",
          "succeeded",
          "failed",
          "interrupted"
        ]
      },
      "Page_ArtifactSummaryResponse": {
        "type": "object",
        "description": "A page of results plus the cursors for the neighbouring pages.",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "A distinct artifact key with its newest version, for `GET /api/v1/artifacts`.",
              "required": [
                "key",
                "version_count",
                "source",
                "digest",
                "size_bytes",
                "downloaded_at"
              ],
              "properties": {
                "digest": {
                  "type": "string",
                  "description": "Content digest of the newest version."
                },
                "downloaded_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "When the newest version was downloaded."
                },
                "key": {
                  "type": "string",
                  "description": "Logical artifact key."
                },
                "size_bytes": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Stored blob size of the newest version, in bytes."
                },
                "source": {
                  "type": "string",
                  "description": "Where the newest version came from."
                },
                "version": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Human-readable version of the newest version, if known."
                },
                "version_count": {
                  "type": "integer",
                  "format": "int64",
                  "description": "How many versions of this key are stored."
                }
              }
            },
            "description": "The rows in this page."
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the next page. Null at the end."
          },
          "prev_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the previous page. Null at the start."
          }
        }
      },
      "Page_ArtifactVersionResponse": {
        "type": "object",
        "description": "A page of results plus the cursors for the neighbouring pages.",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "One stored version of an artifact.",
              "required": [
                "key",
                "digest",
                "source",
                "size_bytes",
                "downloaded_at"
              ],
              "properties": {
                "digest": {
                  "type": "string",
                  "description": "Content digest of the stored blob."
                },
                "downloaded_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "When this version was downloaded."
                },
                "key": {
                  "type": "string",
                  "description": "Logical artifact key."
                },
                "media_type": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "OCI media type, if applicable."
                },
                "size_bytes": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Stored blob size in bytes."
                },
                "source": {
                  "type": "string",
                  "description": "Where this version came from."
                },
                "verified_at": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "description": "When this version was last verified, if ever."
                },
                "version": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Human-readable version, if known."
                }
              }
            },
            "description": "The rows in this page."
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the next page. Null at the end."
          },
          "prev_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the previous page. Null at the start."
          }
        }
      },
      "Page_DownloadResponse": {
        "type": "object",
        "description": "A page of results plus the cursors for the neighbouring pages.",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "One download attempt, returned by `GET /api/v1/downloads`.",
              "required": [
                "id",
                "key",
                "source",
                "status",
                "started_at"
              ],
              "properties": {
                "digest": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Resolved content digest, if it got that far."
                },
                "error": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Failure detail, if any."
                },
                "finished_at": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "description": "When it finished, if it did."
                },
                "id": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Attempt id."
                },
                "key": {
                  "type": "string",
                  "description": "Logical artifact key."
                },
                "progress": {
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "$ref": "#/components/schemas/DownloadProgressResponse",
                      "description": "Live byte progress, present only while running."
                    }
                  ]
                },
                "size_bytes": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int64",
                  "description": "Bytes transferred, recorded on completion."
                },
                "source": {
                  "type": "string",
                  "description": "Where it was fetched from."
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "When the attempt started."
                },
                "status": {
                  "$ref": "#/components/schemas/DownloadStatusResponse",
                  "description": "Lifecycle state."
                }
              }
            },
            "description": "The rows in this page."
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the next page. Null at the end."
          },
          "prev_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Cursor to pass as `?cursor=` for the previous page. Null at the start."
          }
        }
      },
      "VersionResponse": {
        "type": "object",
        "description": "Version information returned by `GET /api/v1/version`.",
        "required": [
          "aperture"
        ],
        "properties": {
          "aperture": {
            "type": "string",
            "description": "Version of the Aperture gateway."
          }
        }
      },
      "OrderParam": {
        "type": "string",
        "enum": [
          "asc",
          "desc"
        ],
        "description": "Sort direction shared by list endpoints."
      },
      "VersionSortParam": {
        "type": "string",
        "enum": [
          "downloaded_at",
          "size_bytes"
        ],
        "description": "Field a version listing is sorted by."
      },
      "DownloadStatusParam": {
        "type": "string",
        "enum": [
          "running",
          "succeeded",
          "failed",
          "interrupted"
        ],
        "description": "Filter for download status."
      }
    }
  }
}
